void loop() {
 
  int sensorValue = analogRead(moisture_sensor); // Reading moisture sensor value from 1380 (pure water) to 3560 (air)
  int humidityPercentage = (sensorValue - 1380) * 100 / (3560 - 1380);
  Serial.print("Soil Moisture Level: ");
  Serial.print(humidityPercentage);
  Serial.println("%");

  int refill_state = digitalRead(water_sensor); // Reading float water sensor state
  if (refill_state == 1){ // When input is HIGH -> bulb is lifted -> Water is sufficent
    Serial.println("Sufficient water is available");
  }
  else { // when input is LOW -> bulb is lowered -> Water supply needs a refill
    Serial.println("INSUFFICIENT WATER SUPPLY");
  }
  
  delay(1000); // Delay for one second before the next reading
}
